# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
# These same values must also be added as GitHub Actions secrets (see SETUP.md).

# From your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# GitHub Pages base path — must match your repo name exactly, with leading and trailing slash
# e.g. /dynamic-schedule-tool/
# Leave as / if using a custom domain
VITE_BASE_PATH=/dynamic-schedule-tool/

# Twilio WhatsApp (optional — only needed for push notifications)
# From twilio.com → Console → Account Info
VITE_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_TWILIO_AUTH_TOKEN=your-auth-token
VITE_TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
